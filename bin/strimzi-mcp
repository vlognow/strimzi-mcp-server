#!/usr/bin/env bash
set -e

PLUGIN_DIR="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"

# Find the latest built JAR (excluding maven's -original suffix)
find_jar() {
  ls -t "${PLUGIN_DIR}/target"/strimzi-mcp-server-*.jar 2>/dev/null | grep -v original | head -1
}

JAR_PATH=$(find_jar)

if [ -z "$JAR_PATH" ]; then
  echo "Building strimzi-mcp-server (first run only — this may take a minute)..." >&2
  if ! "${PLUGIN_DIR}/mvnw" -f "${PLUGIN_DIR}/pom.xml" package -DskipTests -q 2>&1; then
    echo "ERROR: Build failed. Ensure Java 21+ and internet access are available, then restart." >&2
    exit 1
  fi
  JAR_PATH=$(find_jar)
fi

exec java -jar "$JAR_PATH" "$@"
