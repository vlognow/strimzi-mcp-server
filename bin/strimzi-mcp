#!/usr/bin/env bash
set -e

PLUGIN_DIR="${CLAUDE_PLUGIN_ROOT:-$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)}"
JAR_PATH="${PLUGIN_DIR}/target/strimzi-mcp-server.jar"

if [ ! -f "$JAR_PATH" ]; then
  echo "Building strimzi-mcp-server..." >&2
  "${PLUGIN_DIR}/mvnw" -f "${PLUGIN_DIR}/pom.xml" package -DskipTests -q
  # Rename to a stable name regardless of version in pom.xml
  BUILT_JAR=$(ls "${PLUGIN_DIR}/target"/strimzi-mcp-server-*.jar | head -1)
  mv "$BUILT_JAR" "$JAR_PATH"
fi

exec java -jar "$JAR_PATH" "$@"
